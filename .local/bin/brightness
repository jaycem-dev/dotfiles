#!/usr/bin/env bash

if [ "$#" -ne 1 ] || { [ "$1" != "up" ] && [ "$1" != "down" ]; }; then
    echo "Usage: $0 up|down"
    exit 1
fi

STEP=5
SIGN="+"
[ "$1" = "down" ] && SIGN="-"

for disp in $(ddcutil detect --sleep-multiplier 0.5 | grep "Display" | awk '{print $2}' | tr -d ':'); do
    if ddcutil getvcp 10 --display "$disp" --sleep-multiplier 0.5 >/dev/null 2>&1; then
        if ddcutil setvcp 10 $SIGN $STEP --display "$disp" --sleep-multiplier 0.5 >/dev/null 2>&1; then
            vcp_output=$(ddcutil getvcp 10 --display "$disp" --sleep-multiplier 0.5)
            current=$(echo "$vcp_output" | grep -oP 'current value =\s*\K\d+')
            max=$(echo "$vcp_output" | grep -oP 'max value =\s*\K\d+')
            last_percent=$((current * 100 / max))
        else
            external_failed=true
        fi
    fi
done

if command -v brightnessctl >/dev/null 2>&1 && brightnessctl --class=backlight get >/dev/null 2>&1; then
    case "$1" in
    up) delta="+${STEP}%" ;;
    down) delta="${STEP}%-" ;;
    esac
    if brightnessctl --class=backlight set "$delta" >/dev/null 2>&1; then
        current=$(brightnessctl --class=backlight get)
        max=$(brightnessctl --class=backlight max)
        last_percent=$((current * 100 / max))
    else
        internal_failed=true
    fi
fi

if command -v notify-send >/dev/null; then
    [ -n "$last_percent" ] && notify-send -c osd -h string:x-canonical-private-synchronous:osd -h int:value:"${last_percent}" " "
    [ "$external_failed" = "true" ] && notify-send "Brightness Error" "Failed to adjust external monitor brightness"
    [ "$internal_failed" = "true" ] && notify-send "Brightness Error" "Failed to adjust internal display brightness"
fi
