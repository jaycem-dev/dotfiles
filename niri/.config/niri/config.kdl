spawn-at-startup "swayidle"
spawn-sh-at-startup "waybar -c ~/.config/waybar/niri.jsonc"
spawn-at-startup "niriusd"
// Workaraound for Asahi NixOS issues 
spawn-sh-at-startup "niri msg action power-off-monitors; niri msg action power-on-monitors"

workspace "browser"
workspace "dev"
workspace "media"
workspace "chat"
workspace "gaming"

screenshot-path "~/Pictures/Screenshots/screenshot %Y-%m-%d %H-%M-%S.png"
prefer-no-csd // no client-side decorations

// niri msg outputs
output "eDP-1" {
    scale 1.7
}
output "HDMI-A-1" {
    mode "1920x1080"
    scale 1
}

blur {
    offset 10 // default: 3.0
}

gestures {
    hot-corners {
        off
    }
}
cursor {
    xcursor-theme "Bibata-Modern-Classic"
    xcursor-size 24
    hide-after-inactive-ms 5000
}

layout {
    gaps 5
    background-color "transparent"
    center-focused-column "never" // never, always, on-overflow
    always-center-single-column
    default-column-width { proportion 0.9; }
    preset-column-widths {
        proportion 0.5
        proportion 0.9
    }
    preset-window-heights {
        proportion 0.2
        proportion 0.5
    }
    focus-ring {
        off
        width 2
    }
    border {
        on
        width 2
    }
    tab-indicator {
        width 10
        length total-proportion=1.0
        corner-radius 5 
        position "left"
        place-within-column
    }
}

binds {
    Mod+Shift+Slash repeat=false { show-hotkey-overlay; } // shows a list of important hotkeys.
    Mod+Shift+Q { quit; }
    Mod+Tab repeat=false { focus-workspace-previous; }
    Mod+O repeat=false { toggle-overview; }
    Mod+Q repeat=false { close-window; }
    Mod+V       repeat=false { toggle-window-floating; }
    Mod+Shift+V repeat=false { switch-focus-between-floating-and-tiling; }
    Mod+Shift+T { toggle-column-tabbed-display; }
    Mod+Shift+S { screenshot-screen; }
    Mod+C { center-column; }
    Mod+Shift+C { center-visible-columns; }
    Mod+R repeat=false { switch-preset-column-width; }
    Mod+Shift+E repeat=false { expand-column-to-available-width; } // fill empty space
    Mod+Shift+R repeat=false {switch-preset-window-height;}
    Mod+F repeat=false { maximize-column; }
    Mod+Shift+F repeat=false { fullscreen-window; }
    // https://niri-wm.github.io/niri/Configuration%3A-Key-Bindings.html#toggle-keyboard-shortcuts-inhibit
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    // join or exit columns
    Mod+Comma  { consume-or-expel-window-left; }
    Mod+Period { consume-or-expel-window-right; }

    Mod+Left  { focus-column-left; }
    Mod+H     { focus-column-left; }
    Mod+J     { focus-window-or-workspace-down; }
    Mod+Down     { focus-window-or-workspace-down; }
    Mod+K     { focus-window-or-workspace-up; }
    Mod+Up     { focus-window-or-workspace-up; }
    Mod+Right { focus-column-right; }
    Mod+L     { focus-column-right; }
    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+WheelScrollDown      { focus-window-or-workspace-down; }
    Mod+WheelScrollUp        { focus-window-or-workspace-up; }

    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+H     { move-column-left; }
    Mod+Shift+Down     { move-window-down-or-to-workspace-down; }
    Mod+Shift+J     { move-window-down-or-to-workspace-down; }
    Mod+Shift+Up     { move-window-up-or-to-workspace-up; }
    Mod+Shift+K     { move-window-up-or-to-workspace-up; }
    Mod+Shift+Right { move-column-right; }
    Mod+Shift+L     { move-column-right; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    // media keys
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "volume up"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "volume down"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "volume mute"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "volume micmute"; }
    XF86AudioPlay        allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop        allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev        allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true { spawn-sh "playerctl next"; }
    XF86MonBrightnessUp allow-when-locked=true { spawn-sh "brightness up"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn-sh "brightness down"; }
    Shift+XF86MonBrightnessUp { spawn-sh "brightness up 20"; }
    Shift+XF86MonBrightnessDown { spawn-sh "brightness down 20"; }


    // application binds
    Mod+G repeat=false hotkey-overlay-title="Open terminal" { spawn-sh "nirius toggle-follow-mode"; }
    Mod+Space hotkey-overlay-title="Open launcher" { spawn "fuzzel"; }
    Mod+T hotkey-overlay-title="Open terminal" { spawn-sh "kitty"; }
    Mod+N repeat=false hotkey-overlay-title="Open neovim" { spawn-sh "launch-or-focus --tui nvim-projects"; }
    Mod+E repeat=false hotkey-overlay-title="Open yazi" { spawn-sh "launch-or-focus --tui yazi"; }
    Mod+B repeat=false hotkey-overlay-title="Open browser" { spawn-sh "launch-or-focus brave --id brave-browser"; }
    Mod+W repeat=false hotkey-overlay-title="Open Whatsapp (Webapp)" { spawn-sh "launch-or-focus --webapp web.whatsapp.com"; }
    Mod+Shift+M repeat=false hotkey-overlay-title="Open ProtonMail (Webapp)" { spawn-sh "launch-or-focus --webapp mail.proton.me"; }
    Mod+M repeat=false hotkey-overlay-title="Open Spotify (Webapp)" { spawn-sh "launch-or-focus --webapp open.spotify.com"; }
    Mod+Y repeat=false hotkey-overlay-title="Open YouTube (Webapp)" { spawn-sh "launch-or-focus --webapp youtube.com"; }
    Mod+P repeat=false { spawn "dmenu-power"; }
}

input {
    // warp-mouse-to-focus
    focus-follows-mouse max-scroll-amount="30%" // 0% only focus windows that are already fully on screen
    keyboard {
        xkb {
            layout "us"
            variant "colemak_dh_iso"
            options "caps:escape"
        }
    }
    touchpad {
        // tap
        dwt // disable-while-typing
        // dwtp
        // drag false
        // drag-lock
        natural-scroll
        accel-speed 0.1
        // accel-profile "adaptive"
        // scroll-method "two-finger"
        // disabled-on-external-mouse
    }
    mouse {
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "no-scroll"
    }
}

// manual blur for apps that don't support ext-background-effect-v1
layer-rule {
    match namespace="^launcher$"
    background-effect {
        blur true
    }
}


// rounded corners
window-rule {
    geometry-corner-radius 5 
    clip-to-geometry true
}

// Make inactive windows semitransparent with blur
window-rule {
    match is-active=false
    exclude is-floating=true
    opacity 0.9
     background-effect {
        blur true
    }
}

// Open the Firefox and Chromium PIP floating by default.
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    match app-id=r#"zen-beta$"# title="^Picture-in-Picture$"
    match title="^Picture in picture$" // brave pip doesn't set app-id
    open-floating true
    default-floating-position x=5 y=5 relative-to="top-right"
    default-column-width { fixed 400; }
    default-window-height { fixed 225; }
    open-focused false
}

// Block out apps from screen capture.
window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    match app-id=r#"^org\.gnome\.World\.Secrets$"#
    match app-id=r#"^org\.gnome\.seahorse\.Application$"#
    match app-id=r#"^Proton Pass$"#
    block-out-from "screen-capture"
}

// browser workspace apps
window-rule {
    match app-id=r#"brave-browser"#
    match app-id=r#"zen-beta"#
    open-on-workspace "browser"
}
// dev workspace apps
window-rule {
    match app-id=r#"nvim"#
    match app-id=r#"kitty"#
    match app-id=r#"foot"#
    match app-id=r#"Alacritty"#
    match app-id=r#"com.mitchellh.ghostty"#
    open-on-workspace "dev"
}
window-rule {
    match app-id=r#"brave-music.youtube.com__-Default"#
    match app-id=r#"brave-open.spotify.com__-Default"#
    open-on-workspace "media"
}
// chat workspace apps
window-rule {
    match app-id=r#"brave-web.whatsapp.com__-Default"#
    match app-id=r#"signal"#
    match app-id=r#"brave-mail.proton.me__-Default"#
    open-on-workspace "chat"
}
// gaming
window-rule {
    match app-id=r#"steam"#
    match app-id=r#"heroic"#
    open-on-workspace "gaming"
}

include "./colors.kdl"
