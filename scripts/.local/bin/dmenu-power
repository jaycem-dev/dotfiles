#!/usr/bin/env bash

declare -A items=(
    [lock]="’ĆŻ Lock"
    [suspend]="’åå Suspend"
    [reboot]="’ĆĪ Reboot"
    [shutdown]="’Ćæ Shutdown"
)

# Display options with fuzzel
selected=$(printf '%s\n' "${items[@]}" | fuzzel --dmenu)

# Find the key for the selected value and perform action
if [[ -n "$selected" ]]; then
    for key in "${!items[@]}"; do
        if [[ "${items[$key]}" == "$selected" ]]; then
            # confirm=$(printf 'Yes\nNo' | fuzzel --dmenu -p "Confirm ${key}? ")
            # if [[ "$confirm" != "Yes" ]]; then
            #     exit 0
            # fi
            case $key in
            lock)
                swaylock
                ;;
            suspend)
                systemctl suspend
                ;;
            reboot)
                systemctl reboot
                ;;
            shutdown)
                systemctl poweroff
                ;;
            esac
            break
        fi
    done
fi
