timeout 120 'swaylock'
timeout 120 'hyprctl dispatch "hl.dsp.dpms({ action = [[disable]] })"' resume 'hyprctl dispatch "hl.dsp.dpms({ action = [[enable]] })"' 
timeout 120 'brightnessctl -sd kbd_backlight set 0' resume 'brightnessctl -rd kbd_backlight'
timeout 180 'systemctl suspend'
before-sleep 'swaylock'
after-resume 'hyprctl dispatch "hl.dsp.dpms({ action = [[enable]] })"'
