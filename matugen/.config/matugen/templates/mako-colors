# Material You colors

background-color={{colors.background.default.hex}}
text-color={{colors.on_background.default.hex}}
border-color={{colors.primary.default.hex}}
progress-color=over {{colors.primary.default.hex}}
# Per-mode settings

[mode=do-not-disturb]
invisible=1
on-notify=none

[mode=silent]
