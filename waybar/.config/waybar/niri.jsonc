{
    "include": ["~/.config/waybar/common.jsonc"],

    "modules-left": ["niri/workspaces", "wlr/taskbar"],
    "modules-center": ["clock"],
    "modules-right": [
        "privacy",
        "tray",
        "idle_inhibitor",
        "power-profiles-daemon",
        "network",
        "bluetooth",
        "pulseaudio",
        "battery",
    ],

    "niri/workspaces": {
        "format": "{index}",
    },
}
